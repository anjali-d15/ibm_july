# Copy this file to ../.env (the repo root) and fill in your real values.
# That file is .gitignored and must never be committed.

# -----------------------------------------------------------------
# Required for AI generation (P2+)
# -----------------------------------------------------------------

# IBM Cloud API key — created in IAM > API keys
WATSONX_API_KEY=

# watsonx.ai project ID — found in your project's Manage > General tab
WATSONX_PROJECT_ID=

# -----------------------------------------------------------------
# Optional — defaults shown
# -----------------------------------------------------------------

# watsonx.ai regional endpoint (default: us-south)
# Other options: eu-de, eu-gb, jp-tok, au-syd
# WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Express listen port (default: 3001)
# PORT=3001

# Dev CORS origin — set to your Vite dev server URL during local development.
# Leave unset when serving the React build statically from Express (same origin).
# CORS_ORIGIN=http://localhost:5173
